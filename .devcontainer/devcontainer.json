{
  "name": "Sqyre",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "mounts": [
    "source=sqyre-go-mod-cache,target=/go/pkg/mod,type=volume",
    "source=sqyre-go-build-cache,target=/home/vscode/.cache/go-build,type=volume",
    "source=sqyre-opencv-linux,target=/opt/opencv/linux,type=volume",
    "source=sqyre-cargo-home,target=/home/vscode/.cargo,type=volume"
  ],
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "containerEnv": {
    "GOFLAGS": "-tags=gocv_specific_modules",
    "GOTOOLCHAIN": "auto",
    "CARGO_HOME": "/home/vscode/.cargo",
    "RUSTUP_HOME": "/usr/local/rustup"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "rust-lang.rust-analyzer"
      ]
    }
  },
  "postCreateCommand": "sudo chown -R vscode:vscode /go/pkg/mod /home/vscode/.cache/go-build /home/vscode/.cargo /workspace/rust 2>/dev/null || true && rustup component add rust-src 2>/dev/null || true && go mod download && rustc --version && cargo --version",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true
}
