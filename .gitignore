# Editor / local notes
notes.md
.vs
.vscode
/.vscode
/.kiro
.history/
*.vsix

# OCR trained data (downloaded; not committed)
/assets/tessdata/eng.traineddata

# Build outputs
/bin/
/out/
/AppDir/
/VERSION
/target/
**/*.rs.bk

# Linux packaging build artifacts
/appimage-build/
*.AppImage
scripts/linux/packaging/appimage/sqyre.AppDir/
scripts/linux/packaging/appimage/appimage-build/
# mktemp recipe from build-appimage.sh (e.g. .AppImageBuilder.XXXXXX.yml)
scripts/linux/packaging/appimage/.AppImageBuilder.*.yml

# CI / local caches when using workspace paths
.cache/
.devcontainer/builds/

# Local Rust toolchain / cargo caches (workspace installs; not for commit)
.cargo-home/
.rustup-home/

# egui_kittest transient snapshot diffs (if written under docs/images)
docs/images/**/*.diff.png
docs/images/**/*.new.png
**/tests/snapshots/**/*.diff.png
**/tests/snapshots/**/*.new.png
