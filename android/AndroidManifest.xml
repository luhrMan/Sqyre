<?xml version="1.0" encoding="utf-8"?>
<!-- Merge this with Fyne-generated manifest when building for Android.
     Permissions and SqyreAccessibilityService declaration. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <application>
        <service
            android:name="com.sqyre.app.SqyreAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:label="Sqyre">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <!-- Capabilities set in SqyreAccessibilityService.onServiceConnected; or use android:resource="@xml/accessibility_service_config" if res is included -->
        </service>
    </application>
</manifest>
